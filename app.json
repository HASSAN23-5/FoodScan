{
  "expo": {
    "name": "FoodScan AI",
    "slug": "foodscan-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "foodscan",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4A6B53"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.foodscan.ai",
      "infoPlist": {
        "NSCameraUsageDescription": "FoodScan a besoin d'accéder à votre caméra pour scanner les codes-barres des produits alimentaires."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4A6B53"
      },
      "permissions": [
        "android.permission.CAMERA"
      ],
      "package": "com.foodscan.ai"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "FoodScan a besoin d'accéder à votre caméra pour scanner les codes-barres."
        }
      ],
      "expo-font"
    ]
  }
}
