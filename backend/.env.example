# ============================================================
# FoodScan AI - Configuration
# ============================================================
# Copie ce fichier en .env et remplis les valeurs.
# Ne JAMAIS commiter le .env réel dans Git.

# --- Base de données ---
MONGO_URL="mongodb://localhost:27017"
DB_NAME="foodscan_db"

# --- Sécurité ---
JWT_SECRET="change-this-to-a-strong-random-secret-min-32-chars"
ADMIN_EMAIL="admin@foodscan.com"
ADMIN_PASSWORD="Admin123!"

# --- Backend IA ---
# Mode AUTO: si GROQ_API_KEY est défini, le backend utilise Groq (cloud, rapide).
#            sinon, il essaie Ollama en local.
#            si les deux échouent, fallback rule-based intelligent.

# Option 1 - GROQ (cloud, gratuit, ~1-2s, RECOMMANDÉ pour déploiement cloud)
# Crée une clé gratuite sur https://console.groq.com/keys
# GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxx"
# GROQ_MODEL="llama-3.1-8b-instant"

# Option 2 - OLLAMA (local, gratuit, ~5-15s sur CPU sans GPU)
# Nécessite: ollama serve + ollama pull llama3.2:1b
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2:1b"
